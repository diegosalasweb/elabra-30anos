---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const {
  title       = 'Minera El Abra — 30 Años',
  description = 'Producción audiovisual para conmemorar los 30 años de Minera El Abra, su impacto en la industria y la comunidad de Chile.',
  image       = '/images/hero.jpg',
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/images/logo-el-abra.png" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- OG -->
    <meta property="og:type"        content="website" />
    <meta property="og:title"       content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={image} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:ital,wght@0,300;0,400;0,600;1,300&display=swap"
      rel="stylesheet"
    />

  </head>
  <body>
    <slot />
  </body>
</html>
