---

<section class="downloads section">
  <div class="container">
    <p class="eyebrow">Recursos</p>
    <h2 class="downloads__title">Descargar Fotografías</h2>
    <span class="copper-line"></span>
    <div class="downloads__grid">
      <a
        href="https://www.dropbox.com/scl/fo/v1qk5quf0vszuq6n1dddy/ANQ8fnsEpGsg_ArlXYYrhu0?rlkey=04lbakxz60uhqxb8txvafbuob&e=1&dl=0"
        class="downloads__btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Fotografías Set 1
      </a>
      <a
        href="https://www.dropbox.com/scl/fo/2n9xe19wesor1ra54h20u/AFyyD3TaTJxr29D6wOAxXL0?rlkey=ajr92d7x10akr0ozu9v97bawi&e=2&dl=0"
        class="downloads__btn"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        Fotografías Set 2
      </a>
    </div>
  </div>
</section>

<style>
  .downloads {
    background: #0a1e35;
    border-top: 1px solid var(--border);
  }

  .downloads__title {
    font-size: clamp(1.75rem, 4vw, 3rem);
    color: var(--white);
    letter-spacing: 0.03em;
  }

  .downloads__grid {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .downloads__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--copper);
    border: 1px solid var(--copper);
    padding: 0.85rem 2rem;
    transition: background 0.25s ease, color 0.25s ease;
  }

  .downloads__btn:hover {
    background: var(--copper);
    color: #fff;
  }
</style>
